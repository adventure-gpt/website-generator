{
  "name": "website-generator-installer",
  "version": "1.0.0",
  "description": "Cross-platform installer for Website Generator",
  "author": {
    "name": "Website Generator",
    "email": "hello@websitegenerator.app"
  },
  "homepage": "https://github.com/websitegenerator/website-generator",
  "main": "src/main/index.js",
  "scripts": {
    "start": "electron .",
    "start:dry": "electron . --dry-run",
    "prebuild": "node scripts/copy-templates.js",
    "build": "electron-builder",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux",
    "build:win": "electron-builder --win"
  },
  "devDependencies": {
    "electron": "^35.0.0",
    "electron-builder": "^26.0.0"
  }
}
